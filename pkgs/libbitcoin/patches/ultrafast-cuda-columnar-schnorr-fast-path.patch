+__global__ void schnorr_verify_columns_kernel(
+    const uint8_t* __restrict__ pubkeys_x,
+    const uint8_t* __restrict__ msgs,
+    const uint8_t* __restrict__ sigs64,
+    uint8_t* __restrict__ results,
+    int count)
+{
+    const int idx = blockIdx.x * blockDim.x + threadIdx.x;
+    if (idx >= count) return;
+
+    SchnorrSignatureGPU sig;
+    const uint8_t* sig_bytes = sigs64 + static_cast<size_t>(idx) * 64;
+    const uint8_t* pk = pubkeys_x + static_cast<size_t>(idx) * 32;
+    const uint8_t* msg = msgs + static_cast<size_t>(idx) * 32;
+
+    results[idx] =
+        (schnorr_sig_parse_strict(sig_bytes, &sig) &&
+         schnorr_verify(pk, msg, &sig)) ? 1u : 0u;
+}
+
+__global__ void schnorr_verify_collect_columns_kernel(
+    const uint8_t* __restrict__ pubkeys_x,
+    const uint8_t* __restrict__ msgs,
