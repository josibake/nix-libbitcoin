+    int count)
+{
+    const int idx = blockIdx.x * blockDim.x + threadIdx.x;
+    if (idx >= count) return;
+
+    SchnorrSignatureGPU sig;
+    const uint8_t* sig_bytes = sigs64 + static_cast<size_t>(idx) * 64;
+    const uint8_t* pk = pubkeys_x + static_cast<size_t>(idx) * 32;
+    const uint8_t* msg = msgs + static_cast<size_t>(idx) * 32;
+
+    if (schnorr_sig_parse_strict(sig_bytes, &sig) &&
+        schnorr_verify(pk, msg, &sig)) {
+        key_cells[idx] = 0u;
+    }
+}
