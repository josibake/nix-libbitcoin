+#include "secp256k1/ecdsa.hpp"
+#include "secp256k1/precompute.hpp"
+#include "secp256k1/sha256.hpp"
+#include "secp256k1/detail/secure_erase.hpp"
@@ -40,0 +45 @@
+#include <array>
@@ -44,0 +50 @@
+#include <limits>
@@ -82,0 +89,82 @@ enum class EcdsaSigFormat { Compact, Opaque };
+std::uint64_t prefix64_from_x(const std::array<std::uint8_t, 32>& x) noexcept {
+    std::uint64_t out = 0;
+    for (std::size_t i = 0; i < sizeof(out); ++i)
+        out = (out << 8) | x[i];
+    return out;
+}
+
+ufsecp_error_t cpu_sp_scan(const uint8_t scan_privkey32[32],
+                           const uint8_t spend_pubkey33[33],
+                           const uint8_t* tweak_pubkeys33,
+                           size_t n,
+                           uint64_t* prefix64_out) {
+    using secp256k1::EcdsaPublicKey;
+    using secp256k1::ecdsa_pubkey_parse;
+    using secp256k1::SHA256;
+    using secp256k1::fast::KPlan;
+    using secp256k1::fast::Point;
+    using secp256k1::fast::Scalar;
+
+    if (n > (std::numeric_limits<std::size_t>::max() / sizeof(uint64_t)))
+        return UFSECP_ERR_BAD_INPUT;
+
+    std::memset(prefix64_out, 0, n * sizeof(uint64_t));
+
+    try {
+        Scalar scan;
+        if (!Scalar::parse_bytes_strict_nonzero(scan_privkey32, scan))
+            return UFSECP_ERR_BAD_KEY;
+
+        EcdsaPublicKey spend{};
+        if (!ecdsa_pubkey_parse(spend, spend_pubkey33, 33))
+            return UFSECP_ERR_BAD_PUBKEY;
+
+        std::vector<Point> tweaks(n);
+        for (std::size_t i = 0; i < n; ++i) {
+            EcdsaPublicKey tweak{};
+            if (!ecdsa_pubkey_parse(tweak, tweak_pubkeys33 + i * 33, 33))
+                return UFSECP_ERR_BAD_PUBKEY;
+            tweaks[i] = tweak.point;
+        }
+
+        const auto plan = KPlan::from_scalar(scan);
+        secp256k1::detail::secure_erase(&scan, sizeof(scan));
+
+        std::vector<Point> shared(n);
+        Point::batch_scalar_mul_fixed_k(plan, tweaks.data(), n, shared.data());
+
+        std::vector<std::array<std::uint8_t, 33>> shared_comp(n);
+        Point::batch_to_compressed(shared.data(), n, shared_comp.data());
+
+        static const auto tag = SHA256::hash(
+            reinterpret_cast<const std::uint8_t*>("BIP0352/SharedSecret"), 20);
+        std::vector<Scalar> output_tweaks(n);
+
+        for (std::size_t i = 0; i < n; ++i) {
+            SHA256 hash;
+            hash.update(tag.data(), tag.size());
+            hash.update(tag.data(), tag.size());
+            hash.update(shared_comp[i].data(), shared_comp[i].size());
+            const std::uint8_t index[4]{};
+            hash.update(index, sizeof(index));
+            auto digest = hash.finalize();
+            if (!Scalar::parse_bytes_strict_nonzero(digest.data(), output_tweaks[i]))
+                return UFSECP_ERR_ARITH;
+            secp256k1::detail::secure_erase(digest.data(), digest.size());
+        }
+
+        std::vector<Point> generated(n);
+        secp256k1::fast::batch_scalar_mul_generator(
+            output_tweaks.data(), generated.data(), n);
+
+        for (std::size_t i = 0; i < n; ++i)
+            prefix64_out[i] = prefix64_from_x(
+                spend.point.add(generated[i]).x_only_bytes());
+
+        return UFSECP_OK;
+    } catch (...) {
+        std::memset(prefix64_out, 0, n * sizeof(uint64_t));
+        return UFSECP_ERR_INTERNAL;
+    }
+}
+
